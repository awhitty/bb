Output docs/demo.gif
Set Shell "bash"
Set FontSize 14
Set Width 1100
Set Height 620
Set Padding 8
Set Framerate 12
Set TypingSpeed 35ms

Type "bb"
Enter
Sleep 2200ms

Type "/"
Sleep 250ms
Type "subtree=demo-rep"
Enter
Sleep 1200ms

Type "i"
Sleep 250ms
Type "demo-rep.1"
Enter
Sleep 1200ms
Type "R"
Sleep 2s
Type "l"
Sleep 450ms
Type "j"
Sleep 900ms

Type "esc"
Sleep 500ms
Type "esc"
Sleep 700ms
Type "@"
Sleep 2200ms
Type "jj"
Sleep 1400ms

Type "esc"
Sleep 500ms
Type "1"
Sleep 1200ms
